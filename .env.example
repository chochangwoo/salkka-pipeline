# 살까말까 환경변수 템플릿 (v2)
# 이 파일을 복사해서 .env로 저장 후 실제 값 입력
# .env는 절대 git에 올리지 마세요!

# 국토부 실거래가 API (공공데이터포털에서 발급)
# https://www.data.go.kr/data/15126468/openapi.do → "활용신청"
# ※ Decoding 키를 사용하세요 (Encoding 키 X)
MOLIT_API_KEY=여기에_국토부_Decoding_API_키_입력

# 도로명주소 API (행안부, 무료, 사업자 불필요)
# https://business.juso.go.kr/addrlink/openApi/apiExprn.do
JUSO_API_KEY=여기에_도로명주소_API_키_입력

# 카카오맵 REST API (현재 미사용, v3 전환 시 필요)
# https://developers.kakao.com
KAKAO_API_KEY=여기에_카카오_REST_API_키_입력

# OpenAI API (platform.openai.com에서 발급)
OPENAI_API_KEY=여기에_OpenAI_API_키_입력

# Supabase (supabase.com에서 프로젝트 생성 후)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=여기에_Supabase_anon_키_입력

# Resend (resend.com에서 발급)
RESEND_API_KEY=여기에_Resend_API_키_입력
FROM_EMAIL=letter@yourdomain.com
