# 살까말까 환경변수 템플릿
# 이 파일을 복사해서 .env로 저장 후 실제 값 입력
# .env는 절대 git에 올리지 마세요!

# 국토부 실거래가 API (공공데이터포털에서 발급)
# https://www.data.go.kr → "아파트매매 실거래 상세 자료" 검색
MOLIT_API_KEY=여기에_국토부_API_키_입력

# 카카오맵 REST API (카카오 개발자 센터에서 발급)
# https://developers.kakao.com → 앱 생성 → REST API 키
KAKAO_API_KEY=여기에_카카오_REST_API_키_입력

# OpenAI API (platform.openai.com에서 발급)
OPENAI_API_KEY=sk-여기에_OpenAI_API_키_입력

# Supabase (supabase.com에서 프로젝트 생성 후)
SUPABASE_URL=https://여기에_프로젝트_ID.supabase.co
SUPABASE_KEY=여기에_anon_public_키_입력

# Resend (resend.com에서 발급)
RESEND_API_KEY=re_여기에_Resend_API_키_입력
FROM_EMAIL=letter@여기에_도메인.com
